# ============================================================
# FILE KONFIGURASI E-ABSENSI
# Salin file ini menjadi ".env" lalu isi nilainya
# ============================================================

# --- DATABASE (Wajib) ---
# Alamat koneksi PostgreSQL
# Format: postgresql://username:password@host:port/nama_database
DATABASE_URL=postgresql://postgres:password@localhost:5432/eabsensi

# --- KEAMANAN SESSION (Wajib) ---
# Isi dengan teks acak yang panjang (minimal 32 karakter)
# Contoh: gunakan password generator online
SESSION_SECRET=ganti_dengan_teks_acak_yang_panjang_dan_aman_123456

# --- BACKUP GOOGLE DRIVE (Opsional) ---
# Isi jika ingin menggunakan fitur backup ke Google Drive
# Cara mendapatkan: lihat panduan di halaman Konfigurasi WebApps
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Ganti dengan domain/alamat server kamu:
GOOGLE_REDIRECT_URI=https://domain-kamu.com/api/auth/google/callback

# --- PORT (Opsional) ---
# Port server, default 5000 jika tidak diisi
PORT=5000
